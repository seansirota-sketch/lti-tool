PORT=3000
NODE_ENV=development

# Where users are redirected after launch.
VAULTAU_URL=https://vaultau.example.com/lti/callback

# Shared signing key with VaultAU for HS256 handoff JWT validation.
LTI_HANDOFF_SIGNING_KEY=replace-with-strong-secret

# Optional JWT tuning values.
LTI_HANDOFF_ISSUER=lti-tool-bridge
LTI_HANDOFF_AUDIENCE=vaultau
LTI_HANDOFF_EXP_SECONDS=300

# Optional allowlist for launch issuer (Moodle host).
LTI_ALLOWED_ISSUER=

# Stage 2 LTI 1.3 OIDC settings.
LTI_TOOL_BASE_URL=http://localhost:3000
LTI_LOGIN_PATH=/lti/login
LTI_CALLBACK_PATH=/lti/callback
LTI_JWKS_PATH=/.well-known/jwks.json
LTI_STATE_TTL_SECONDS=600

# Platform registration (Moodle values).
LTI_PLATFORM_ISSUER=
LTI_PLATFORM_CLIENT_ID=
LTI_PLATFORM_AUTH_LOGIN_URL=
LTI_PLATFORM_JWKS_URL=
LTI_PLATFORM_DEPLOYMENT_ID=
